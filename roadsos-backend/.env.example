# API Keys
GEMINI_API_KEY=
FIREBASE_CREDENTIALS=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=

# Database
DATABASE_URL=sqlite:///./roadsos.db

# App Settings
DEBUG=false

# LLM provider: "ollama" for the local chatbot or "gemini" for Gemini API
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Optional route provider. Leave empty to use RoadSoS local Dijkstra fallback.
# Example: https://router.project-osrm.org
OSRM_BASE_URL=

# Danger-zone alerts
DANGER_ZONE_ALERT_RADIUS_KM=10.0
DANGER_ZONE_SMS_COOLDOWN_MINUTES=45
